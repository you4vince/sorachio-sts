# Model Files (GGUF, GGML, ONNX, Checkpoints)
# These are extremely large and should not be pushed to GitHub
models/llm1/*.gguf
models/llm2/*.gguf
models/stt/*.bin
models/stt/*.onnx
# Or keep folder structure but ignore all models:
models/**/*
# But do not ignore the directory structure itself:
!models/
!models/llm1/
!models/llm2/
!models/stt/

